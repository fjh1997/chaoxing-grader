CDP_PROXY_URL=http://localhost:3456

# OpenAI-compatible vision API.
MIMO_ENDPOINT=https://api.openai.com/v1
MIMO_MODEL=mimo-v2.5
MIMO_API_KEY=replace-with-your-api-key

# Optional tuning.
MIMO_MAX_IMAGES=6
MIMO_IMAGE_MAX_BYTES=900000
MIMO_IMAGE_MAX_SIDE=1800
MIMO_JPEG_QUALITY=82
MIMO_TIMEOUT_MS=120000
MIMO_RETRIES=4
SIMILARITY_WORKERS=8
